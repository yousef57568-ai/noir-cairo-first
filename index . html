    :root {
      --instagram: "Noir_Cairo2026";
      --gold:      #D4AF37;
      --black:     #000000;
      --white:     #FFFFFF;
      --dgrey:     #1A1A1A;
      --mgrey:     #2a2a2a;
      --lgrey:     #888;
      --serif:     'Cormorant Garamond', Georgia, serif;
      --sans:      'Montserrat', sans-serif;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body {
      background: var(--black);
      color: var(--white);
      font-family: var(--sans);
      font-weight: 300;
      letter-spacing: 0.08em;
      overflow-x: hidden;
      cursor: none;
    }

    #cursor {
      width: 12px; height: 12px;
      border: 1px solid var(--gold);
      border-radius: 50%;
      position: fixed; top: 0; left: 0;
      pointer-events: none; z-index: 9999;
      transform: translate(-50%,-50%);
      transition: width .25s, height .25s, background .25s, opacity .3s;
    }
    #cursor.big { width: 40px; height: 40px; background: rgba(212,175,55,.12); }

    #loader {
      position: fixed; inset: 0;
      background: var(--black);
      display: flex; align-items: center; justify-content: center;
      z-index: 8888;
      transition: opacity .7s ease, visibility .7s;
    }
    #loader.gone { opacity: 0; visibility: hidden; }
    .loader-text {
      font-family: var(--serif);
      font-size: clamp(2.5rem, 8vw, 5rem);
      font-weight: 300;
      letter-spacing: 0.35em;
      color: var(--gold);
      animation: pulse 1.5s ease-in-out infinite;
    }
    @keyframes pulse { 0%,100%{opacity:.3} 50%{opacity:1} }

    nav {
      position: fixed; top: 0; width: 100%; z-index: 100;
      display: flex; align-items: center; justify-content: space-between;
      padding: 1.5rem 4rem;
      border-bottom: 1px solid rgba(212,175,55,.15);
      background: rgba(0,0,0,.85);
      backdrop-filter: blur(12px);
      transition: padding .4s;
    }
    nav.scrolled { padding: 1rem 4rem; }
    .nav-logo {
      font-family: var(--serif);
      font-size: 1.4rem; font-weight: 400;
      letter-spacing: 0.4em; color: var(--gold); text-decoration: none;
    }
    .nav-links { display: flex; gap: 3rem; list-style: none; }
